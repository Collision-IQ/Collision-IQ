# --- AI provider (Claude / Anthropic is primary) ---
# Provider routing. Defaults to "anthropic". Set to "openai" only for the
# legacy fallback, or "openclaw" for the local gateway.
COLLISION_IQ_PRIMARY_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_PRIMARY=claude-opus-4-8
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Embeddings / RAG vector search (Claude has no embeddings API).
VOYAGE_API_KEY=
VOYAGE_EMBED_MODEL=voyage-3-large

# Optional legacy OpenAI fallback (not required when provider=anthropic).
OPENAI_API_KEY=

# FAL AI (OpenRouter vision queue)
FAL_KEY=
FAL_OPENROUTER_VISION_MODEL=google/gemini-2.5-flash

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_1=
ELEVENLABS_VOICE_ID_2=
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
CCC_SECURE_SHARE_SANDBOX_WEBHOOK_SECRET=
CCC_SECURE_SHARE_PRODUCTION_WEBHOOK_SECRET=
CCC_SECURE_SHARE_SECRET_MODE=monitor
CCC_SECURE_SHARE_ENFORCE_IP_ALLOWLIST=false

# --- Pro integrations: CCC Secure Share Import + Scan IQ ---
CCC_SECURE_SHARE_PIPELINE_ENABLED=false
SCAN_IQ_ENABLED=false

# --- MOTOR DaaS (limited 15-vehicle sandbox; keys are server-only, never NEXT_PUBLIC_) ---
MOTOR_DAAS_ENABLED=false
MOTOR_DAAS_BASE_URL=https://api.motor.com/v1
MOTOR_DAAS_PUBLIC_KEY=
MOTOR_DAAS_PRIVATE_KEY=
MOTOR_DAAS_ATTRIBUTE_STANDARD=MOTOR
MOTOR_DAAS_DTC_ENABLED=false
MOTOR_DAAS_TIMEOUT_MS=15000
MOTOR_DAAS_CACHE_TTL_SECONDS=86400
MOTOR_DAAS_LOG_LEVEL=metadata-only
# Optional route templates ({motorVehicleId}/{code}); align to api.motor.com/v1/documentation.
MOTOR_DAAS_DTC_VEHICLE_ROUTE_TEMPLATE=
# Set ONLY after verifying a general/reference DTC route works without a vehicle id.
MOTOR_DAAS_DTC_GENERAL_ROUTE_TEMPLATE=
