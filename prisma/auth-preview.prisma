datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SubscriptionPlan {
  STARTER
  PRO
  TEAM
}

enum SubscriptionStatus {
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
}

enum ShopRole {
  OWNER
  ADMIN
  MEMBER
}

enum ConsentStatus {
  ACCEPTED
  REVOKED
  EXPIRED
}

enum UsageKind {
  ANALYSIS_COMPLETED
}

model User {
  id              String   @id @default(cuid())
  clerkUserId     String   @unique
  email           String?  @unique
  firstName       String?
  lastName        String?
  imageUrl        String?
  isPlatformAdmin Boolean  @default(false)
  defaultShopId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  defaultShop      Shop?             @relation("UserDefaultShop", fields: [defaultShopId], references: [id])
  consents         ChatConsent[]
  featureOverrides FeatureOverride[]
  memberships      ShopMembership[]
  ownedShops       Shop[]            @relation("ShopOwner")
  subscriptions    Subscription[]
  usageRecords     UsageRecord[]
}

model Shop {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  ownerId          String
  stripeCustomerId String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  owner            User              @relation("ShopOwner", fields: [ownerId], references: [id])
  defaultUsers     User[]            @relation("UserDefaultShop")
  featureOverrides FeatureOverride[]
  memberships      ShopMembership[]
  subscriptions    Subscription[]
  usageRecords     UsageRecord[]
}

model ShopMembership {
  id           String   @id @default(cuid())
  shopId       String
  userId       String
  role         ShopRole @default(MEMBER)
  isSeatActive Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([shopId, userId])
  @@index([userId])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String?
  shopId               String?
  stripeCustomerId     String?
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 SubscriptionPlan   @default(STARTER)
  status               SubscriptionStatus @default(INCOMPLETE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  shop         Shop?         @relation(fields: [shopId], references: [id], onDelete: SetNull)
  usageRecords UsageRecord[]

  @@index([userId])
  @@index([shopId])
  @@index([status])
}

model UsageRecord {
  id             String    @id @default(cuid())
  userId         String?
  shopId         String?
  subscriptionId String?
  kind           UsageKind
  periodKey      String
  quantity       Int       @default(1)
  metadata       Json?
  createdAt      DateTime  @default(now())

  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  shop         Shop?         @relation(fields: [shopId], references: [id], onDelete: SetNull)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId, kind, periodKey])
  @@index([shopId, kind, periodKey])
}

model ChatConsent {
  id              String        @id @default(cuid())
  userId          String
  status          ConsentStatus @default(ACCEPTED)
  acceptedAt      DateTime
  termsVersion    String
  privacyVersion  String
  checkboxChecked Boolean
  ipAddress       String?
  userAgent       String?
  sessionId       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, acceptedAt])
}

model FeatureOverride {
  id         String    @id @default(cuid())
  userId     String?
  shopId     String?
  featureKey String
  enabled    Boolean
  notes      String?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop Shop? @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([userId, featureKey])
  @@index([shopId, featureKey])
}